{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID from Firebase Auth." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's full name." },
        "wishlist": { "type": "array", "items": { "type": "string" }, "description": "List of product IDs in the wishlist." },
        "addresses": { "type": "array", "items": { "$ref": "Address" }, "description": "List of shipping addresses." }
      },
      "required": ["uid", "email"]
    },
    "Address": {
      "title": "Address",
      "description": "A shipping address.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "district": { "type": "string" },
        "area": { "type": "string" },
        "address": { "type": "string" },
        "isDefault": { "type": "boolean" }
      },
      "required": ["id", "fullName", "phone", "district", "area", "address"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "CartItem" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "$ref": "Address" },
        "paymentMethod": { "type": "string", "enum": ["COD", "Online"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "items", "total", "status", "shippingAddress", "paymentMethod", "createdAt"]
    },
    "CartItem": {
      "title": "Cart Item",
      "description": "An item in the shopping cart.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "integer" },
        "selectedSize": { "type": "string" },
        "selectedColor": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "price", "quantity", "selectedSize", "selectedColor"]
    },
    "Review": {
      "title": "Review",
      "description": "A product review.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "productId", "userId", "userName", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer order documents."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product review documents."
    }
  }
}
